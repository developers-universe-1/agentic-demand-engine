# ───────────────────────────────────────────────
# MCP Demand Engine — Environment Configuration
# ───────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# Demo mode works without any of these — just cp .env.example .env and run.

# ─── LLM Provider ───
# Required for live analysis mode (demo mode works without this)
# Get your key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-key-here

# ─── MCP Transport ───
# Set to 'stdio' for CLI integration, 'sse' for HTTP streaming
# Default: sse
MCP_TRANSPORT=sse

# ─── Data Sources ───
# Required for live signal detection (demo mode works without these)
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
APOLLO_API_KEY=
CLEARBIT_API_KEY=

# ─── CRM ───
# Required for live CRM routing (demo mode works without these)
SALESFORCE_CLIENT_ID=
SALESFORCE_CLIENT_SECRET=
HUBSPOT_API_KEY=

# ─── Notifications ───
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
